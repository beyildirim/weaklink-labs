# Get all lab IDs for a given tier number
get_tier_labs() {
    local tier_num="$1"
    local ids=()
    for tier_dir in "$LABS_ROOT"/tier-${tier_num}-*/; do
        [[ -d "$tier_dir" ]] || continue
        for lab_dir in "$tier_dir"/*/; do
            [[ -d "$lab_dir" ]] || continue
            [[ -f "${lab_dir}/lab.yml" ]] || continue
            ids+=("$(read_lab_yml "$lab_dir" "id")")
        done
    done
    echo "${ids[@]}"
}

# Get all lab IDs across all tiers
get_all_labs() {
    local ids=()
    for tier_dir in "$LABS_ROOT"/tier-*/; do
        [[ -d "$tier_dir" ]] || continue
        for lab_dir in "$tier_dir"/*/; do
            [[ -d "$lab_dir" ]] || continue
            [[ -f "${lab_dir}/lab.yml" ]] || continue
            ids+=("$(read_lab_yml "$lab_dir" "id")")
        done
    done
    echo "${ids[@]}"
}

# Check if achievement is unlocked. Returns 0 if unlocked, 1 if locked.
# Sets ACHIEVE_LABS to the list of required labs that were completed.
check_achievement() {
    local requirement="$1"
    ACHIEVE_LABS=()

    case "$requirement" in
        any:*)
            local needed="${requirement#any:}"
            local count=0
            for lab_id_file in "$PROGRESS_DIR"/*.completed; do
                [[ -f "$lab_id_file" ]] || continue
                local lid
                lid=$(basename "$lab_id_file" .completed)
                ACHIEVE_LABS+=("$lid")
                count=$((count + 1))
                [[ $count -ge $needed ]] && return 0
            done
            return 1
            ;;
        tier:*)
            local t="${requirement#tier:}"
            local labs
            labs=$(get_tier_labs "$t")
            [[ -z "$labs" ]] && return 1
            for lid in $labs; do
                if is_completed "$lid"; then
                    ACHIEVE_LABS+=("$lid")
                else
                    return 1
                fi
            done
            return 0
            ;;
        tiers:*)
            local range="${requirement#tiers:}"
            local start="${range%-*}"
            local end="${range#*-}"
            for ((t=start; t<=end; t++)); do
                local labs
                labs=$(get_tier_labs "$t")
                [[ -z "$labs" ]] && return 1
                for lid in $labs; do
                    if is_completed "$lid"; then
                        ACHIEVE_LABS+=("$lid")
                    else
                        return 1
                    fi
                done
            done
            return 0
            ;;
        all)
            local labs
            labs=$(get_all_labs)
            [[ -z "$labs" ]] && return 1
            for lid in $labs; do
                if is_completed "$lid"; then
                    ACHIEVE_LABS+=("$lid")
                else
                    return 1
                fi
            done
            return 0
            ;;
    esac
    return 1
}

# Get the earliest completion date for the labs relevant to an achievement
get_achievement_date() {
    local latest=""
    for lid in "${ACHIEVE_LABS[@]}"; do
        local ts_file="${PROGRESS_DIR}/${lid}.completed"
        if [[ -f "$ts_file" ]]; then
            local ts
            ts=$(cat "$ts_file")
            # Compare dates -- take the latest (achievement unlocks when last lab completes)
            if [[ -z "$latest" ]] || [[ "$ts" > "$latest" ]]; then
                latest="$ts"
            fi
        fi
    done
    echo "$latest"
}

# Get user name from git config or whoami
get_user_name() {
    local name
    name=$(git config user.name 2>/dev/null || true)
    if [[ -z "$name" ]]; then
        name=$(whoami)
    fi
    echo "$name"
}

# Generate verification ID: sha256 of user+achievement+date, first 8 chars
make_verification_id() {
    local achieve_id="$1"
    local user="$2"
    local date="$3"
    local hash
    hash=$(echo -n "${user}${achieve_id}${date}" | shasum -a 256 | cut -c1-8)
    echo "$hash"
}

# Generate challenge hash from concatenated completion timestamps
make_challenge_hash() {
    local hash_input=""
    for lid in "${ACHIEVE_LABS[@]}"; do
        local ts_file="${PROGRESS_DIR}/${lid}.completed"
        if [[ -f "$ts_file" ]]; then
            hash_input+=$(cat "$ts_file")
        fi
    done
    local hash
    hash=$(echo -n "$hash_input" | shasum -a 256 | cut -c1-64)
    echo "sha256:${hash}"
}

