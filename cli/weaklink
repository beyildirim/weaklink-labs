case "${1:-}" in
    assess)
        cmd_assess
        ;;
    shell)
        cmd_shell
        ;;
    path)
        cmd_path
        ;;
    verify)
        [[ -z "${2:-}" ]] && { echo "Usage: weaklink verify <lab-id>"; exit 1; }
        cmd_verify "$2"
        ;;
    hint)
        [[ -z "${2:-}" ]] && { echo "Usage: weaklink hint <lab-id>"; exit 1; }
        cmd_hint "$2"
        ;;
    info)
        [[ -z "${2:-}" ]] && { echo "Usage: weaklink info <lab-id>"; exit 1; }
        cmd_info "$2"
        ;;
    status)
        cmd_status
        ;;
    logs)
        cmd_logs
        ;;
    reset)
        [[ -z "${2:-}" ]] && { echo "Usage: weaklink reset <lab-id>"; exit 1; }
        cmd_reset "$2"
        ;;
    report)
        shift
        if [[ "${1:-}" == "--json" ]]; then
            cmd_report_json
        elif [[ "${1:-}" == "--csv" ]]; then
            cmd_report_csv
        elif [[ "${1:-}" == "--team" ]]; then
            shift
            cmd_report_team "$@"
        else
            cmd_report_pretty
        fi
        ;;
    achieve)
        shift
        cmd_achieve "$@"
        ;;
    *)
        echo ""
        echo "  WeakLink Labs (weaklink)"
        echo ""
        echo "  Usage:"
        echo "    weaklink assess            Placement test to skip Tier 0"
        echo "    weaklink shell             Open workstation shell"
        echo "    weaklink path              Show the learning roadmap"
        echo "    weaklink verify <lab-id>   Check lab completion"
        echo "    weaklink hint <lab-id>     Get a hint"
        echo "    weaklink info <lab-id>     Show lab details"
        echo "    weaklink status            Pod status overview"
        echo "    weaklink logs              View setup job logs"
        echo "    weaklink reset <lab-id>    Reset lab progress"
        echo "    weaklink report            Completion report (pretty)"
        echo "    weaklink report --json     Machine-readable JSON report"
        echo "    weaklink report --csv      CSV report for spreadsheets"
        echo "    weaklink report --team     Aggregate team report"
        echo "    weaklink achieve           Show achievements"
        echo "    weaklink achieve --generate  Generate SVG badges"
        echo "    weaklink achieve --share     Generate badges + LinkedIn posts"
        echo "    weaklink achieve --proof     Generate JSON attestations"
        echo ""
        ;;
esac
