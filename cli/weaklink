#----------------------------------------------------------------------
# Achievement commands
#----------------------------------------------------------------------

cmd_achieve() {
    local do_generate=false
    local do_share=false
    local do_proof=false

    for arg in "$@"; do
        case "$arg" in
            --generate) do_generate=true ;;
            --share)    do_generate=true; do_share=true ;;
            --proof)    do_proof=true ;;
        esac
    done

    local badge_dir="${PROGRESS_DIR}/badges"
    if $do_generate || $do_share || $do_proof; then
        mkdir -p "$badge_dir"
    fi

    local user_name
    user_name=$(get_user_name)
    local unlocked_count=0
    local total_count=${#ACHIEVEMENTS[@]}
    local unlocked_lines=()
    local locked_lines=()

    for entry in "${ACHIEVEMENTS[@]}"; do
        IFS='|' read -r a_id a_name a_desc a_icon a_color a_tier a_req <<< "$entry"

        if check_achievement "$a_req"; then
            unlocked_count=$((unlocked_count + 1))
            local a_date
            a_date=$(get_achievement_date)
            local a_date_short
            a_date_short=$(echo "$a_date" | cut -c1-10)
            local verify_id
            verify_id=$(make_verification_id "$a_id" "$user_name" "$a_date")

            # Record unlock date if not already stored
            if [[ ! -f "${PROGRESS_DIR}/achieve-${a_id}.unlocked" ]]; then
                echo "$a_date" > "${PROGRESS_DIR}/achieve-${a_id}.unlocked"
            fi

            unlocked_lines+=("$(printf "    ${GREEN}[%s]${NC} %-38s %s" "$a_icon" "$a_name ($a_tier)" "$a_date_short")")

            # Generate badge SVG
            if $do_generate; then
                generate_badge_svg "$a_id" "$a_name" "$a_desc" "$a_color" "$a_tier" "$user_name" "$a_date_short" "$verify_id" "$a_icon" "${badge_dir}/${a_id}.svg"
            fi

            # Generate LinkedIn post
            if $do_share; then
                local linkedin_desc
                linkedin_desc=$(get_linkedin_desc "$a_id")
                [[ -z "$linkedin_desc" ]] && linkedin_desc="$a_desc"
                cat > "${badge_dir}/${a_id}-linkedin.txt" << LINKEDINEOF
Completed the ${a_name} track on WeakLink Labs - an open-source, hands-on supply chain security training platform. ${linkedin_desc} #SupplyChainSecurity #AppSec #WeakLinkLabs
LINKEDINEOF
            fi

            # Generate proof attestation
            if $do_proof; then
                local labs_json="["
                local first=true
                for lid in "${ACHIEVE_LABS[@]}"; do
                    if $first; then
                        first=false
                    else
                        labs_json+=", "
                    fi
                    labs_json+="\"${lid}\""
                done
                labs_json+="]"

                local challenge_hash
                challenge_hash=$(make_challenge_hash)

                cat > "${badge_dir}/${a_id}-proof.json" << PROOFEOF
{
  "platform": "weaklink-labs",
  "version": "0.1.0",
  "achievement": "${a_id}",
  "title": "${a_name}",
  "user": "${user_name}",
  "labs_completed": ${labs_json},
  "completed_at": "${a_date}",
  "verification_id": "WL-${verify_id}",
  "challenge_hash": "${challenge_hash}"
}
PROOFEOF
            fi
        else
            locked_lines+=("$(printf "    ${DIM}[%s] %-38s %s${NC}" "$a_icon" "$a_name ($a_tier)" "$a_desc")")
        fi
    done

    # Display achievement status
    echo ""
    echo -e "  ${BOLD}WEAKLINK LABS ACHIEVEMENTS${NC}"
    echo ""

    if [[ ${#unlocked_lines[@]} -gt 0 ]]; then
        echo -e "  ${GREEN}${BOLD}Unlocked:${NC}"
        for line in "${unlocked_lines[@]}"; do
            echo -e "$line"
        done
        echo ""
    fi

    if [[ ${#locked_lines[@]} -gt 0 ]]; then
        echo -e "  ${DIM}${BOLD}Locked:${NC}"
        for line in "${locked_lines[@]}"; do
            echo -e "$line"
        done
        echo ""
    fi

    echo -e "  ${BOLD}Progress:${NC} ${unlocked_count}/${total_count} achievements unlocked"
    echo ""

    # Report generated files
    if $do_generate; then
        local svg_count
        svg_count=$(find "$badge_dir" -name "*.svg" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}Generated ${svg_count} badge(s) in ${badge_dir}/${NC}"
    fi
    if $do_share; then
        local txt_count
        txt_count=$(find "$badge_dir" -name "*-linkedin.txt" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}Generated ${txt_count} LinkedIn post(s) in ${badge_dir}/${NC}"
    fi
    if $do_proof; then
        local json_count
        json_count=$(find "$badge_dir" -name "*-proof.json" 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}Generated ${json_count} attestation(s) in ${badge_dir}/${NC}"
    fi
    if $do_generate || $do_share || $do_proof; then
        echo ""
    fi
}

