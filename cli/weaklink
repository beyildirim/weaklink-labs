#!/usr/bin/env bash
#
# weaklink -- WeakLink Labs CLI
#
# Usage:
#   weaklink assess            Placement test to skip Tier 0
#   weaklink path              Show the learning roadmap and progress
#   weaklink shell             Open a shell in the workstation pod
#   weaklink verify <lab-id>   Check if you completed the lab
#   weaklink hint <lab-id>     Get a progressive hint
#   weaklink info <lab-id>     Show lab details
#   weaklink status            Show pod status
#   weaklink logs              Show setup job logs
#   weaklink reset <lab-id>    Reset a lab to its initial state
#   weaklink report            Generate a completion report
#   weaklink report --json     Machine-readable JSON report
#   weaklink report --csv      CSV report for spreadsheets
#   weaklink report --team     Aggregate team report from JSON inputs
#   weaklink achieve           Show achievements and progress
#   weaklink achieve --generate Generate SVG badges for unlocked achievements
#   weaklink achieve --share   Generate badges + LinkedIn post text
#   weaklink achieve --proof   Generate JSON attestation files

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LABS_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)/labs"
PROGRESS_DIR="${HOME}/.weaklink"
NAMESPACE="weaklink"

mkdir -p "$PROGRESS_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

#----------------------------------------------------------------------
# Helpers
#----------------------------------------------------------------------

find_lab_dir() {
    local lab_id="$1"
    find "$LABS_ROOT" -maxdepth 2 -type d -name "${lab_id}-*" 2>/dev/null | head -1
}

read_lab_yml() {
    local lab_dir="$1"
    local field="$2"
    grep "^${field}:" "${lab_dir}/lab.yml" 2>/dev/null | sed "s/^${field}: *//" | sed 's/^"//' | sed 's/"$//'
}

is_completed() {
    local lab_id="$1"
    [[ -f "${PROGRESS_DIR}/${lab_id}.completed" ]]
}

mark_completed() {
    local lab_id="$1"
    date -u +"%Y-%m-%dT%H:%M:%SZ" > "${PROGRESS_DIR}/${lab_id}.completed"
}

get_hint_count() {
    local lab_id="$1"
    cat "${PROGRESS_DIR}/${lab_id}.hints" 2>/dev/null || echo "0"
}

increment_hint() {
    local lab_id="$1"
    local current
    current=$(get_hint_count "$lab_id")
    echo $((current + 1)) > "${PROGRESS_DIR}/${lab_id}.hints"
}

get_workstation_pod() {
    kubectl get pods -n "$NAMESPACE" -l app.kubernetes.io/name=workstation \
        -o jsonpath='{.items[0].metadata.name}' 2>/dev/null
}

check_cluster() {
    if ! kubectl get namespace "$NAMESPACE" &>/dev/null; then
        echo -e "${RED}Error: WeakLink Labs is not running.${NC}"
        echo -e "Run '${BOLD}./start.sh${NC}' to start the platform."
        exit 1
    fi
}

#----------------------------------------------------------------------
# Assessment questions
#----------------------------------------------------------------------

# Format: QUESTION|OPTION_A|OPTION_B|OPTION_C|OPTION_D|CORRECT_LETTER|TOPIC
ASSESS_QUESTIONS=(
    'What does `git diff HEAD~1` show?|changes in last commit|staged changes|untracked files|merge conflicts|a|Git'
    'What prevents direct pushes to main?|.gitignore|branch protection rules|git hooks only|repository permissions|b|Git'
    'In a supply chain attack via Git, an attacker would most likely:|delete the repo|modify a build script in a PR|change the README|add a .gitignore|b|Git'
    'When you run `pip install <package>`, what file can execute arbitrary code?|README.md|setup.py|requirements.txt|__init__.py|b|Package Managers'
    'What does `--extra-index-url` do in pip?|replaces the default registry|adds an additional registry to check|disables the cache|enables verbose mode|b|Package Managers'
    'What is a lockfile?|a file that prevents package installation|an exact snapshot of all dependency versions|a password file for private registries|a log of all pip commands|b|Package Managers'
    'What does `--require-hashes` do?|encrypts packages|verifies package integrity via checksums|hashes the requirements file|enables TLS|b|Package Managers'
    'Docker tags like `:latest` are:|immutable -- always point to the same image|mutable -- can be reassigned to different images|only used in development|automatically versioned|b|Containers'
    'What uniquely identifies a Docker image regardless of tag changes?|image name|tag|digest (sha256 hash)|Dockerfile|c|Containers'
    'An attacker who pushes a new image with the same tag to a registry is performing:|registry confusion|tag poisoning|layer injection|manifest confusion|b|Containers'
)

#----------------------------------------------------------------------
# Commands
#----------------------------------------------------------------------

cmd_shell() {
    check_cluster
    local pod
    pod=$(get_workstation_pod)

    if [[ -z "$pod" ]]; then
        echo -e "${RED}Error: Workstation pod not found.${NC}"
        echo "Check status with: weaklink status"
        exit 1
    fi

    echo -e "${DIM}Connecting to workstation pod: ${pod}${NC}"
    kubectl exec -it -n "$NAMESPACE" "$pod" -- /bin/bash -l
}

cmd_path() {
    echo ""
    echo -e "${BOLD}  WEAKLINK LABS${NC}"
    echo -e "  ══════════════"
    echo ""

    for tier_dir in "$LABS_ROOT"/tier-*/; do
        [[ -d "$tier_dir" ]] || continue

        local tier_name
        tier_name=$(basename "$tier_dir" | sed 's/tier-[0-9]*-//' | tr '-' ' ' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')
        local tier_num
        tier_num=$(basename "$tier_dir" | grep -o 'tier-[0-9]*' | grep -o '[0-9]*')

        # Check if tier has any labs
        local dir_count
        dir_count=$(find "$tier_dir" -maxdepth 1 -type d ! -name "$(basename "$tier_dir")" 2>/dev/null | wc -l)

        echo -e "  ${BOLD}Tier ${tier_num}: ${tier_name}${NC}"

        if [[ $dir_count -eq 0 ]]; then
            echo -e "    ${DIM}-- Coming soon${NC}"
            echo ""
            continue
        fi

        for lab_dir in "$tier_dir"/*/; do
            [[ -d "$lab_dir" ]] || continue
            [[ -f "${lab_dir}/lab.yml" ]] || continue

            local lab_id
            lab_id=$(read_lab_yml "$lab_dir" "id")
            local title
            title=$(read_lab_yml "$lab_dir" "title")
            local difficulty
            difficulty=$(read_lab_yml "$lab_dir" "difficulty")

            local icon
            if is_completed "$lab_id"; then
                icon="${GREEN}[done]${NC}"
            else
                # Check prerequisites
                local prereqs
                prereqs=$(read_lab_yml "$lab_dir" "prerequisites")
                if [[ -n "$prereqs" && "$prereqs" != "none" && "$prereqs" != "[]" ]]; then
                    local all_met=true
                    for prereq in $(echo "$prereqs" | tr -d '[]"' | tr ',' '\n' | tr -d ' '); do
                        if [[ -n "$prereq" ]] && ! is_completed "$prereq"; then
                            all_met=false
                            break
                        fi
                    done
                    if $all_met; then
                        icon="[    ]"
                    else
                        icon="${DIM}[lock]${NC}"
                    fi
                else
                    icon="[    ]"
                fi
            fi

            local diff_badge=""
            case "$difficulty" in
                beginner)     diff_badge="${GREEN}*${NC}" ;;
                intermediate) diff_badge="${YELLOW}**${NC}" ;;
                advanced)     diff_badge="${RED}***${NC}" ;;
            esac

            printf "    %b  %-4s %-45s %b\n" "$icon" "$lab_id" "$title" "$diff_badge"
        done
        echo ""
    done

    echo -e "  ${DIM}Legend: [done] completed  [    ] available  [lock] locked${NC}"
    echo -e "  ${DIM}Difficulty: ${GREEN}*${NC}${DIM} beginner  ${YELLOW}**${NC}${DIM} intermediate  ${RED}***${NC}${DIM} advanced${NC}"
    echo ""
}

cmd_verify() {
    local lab_id="$1"

    check_cluster

    local lab_dir
    lab_dir=$(find_lab_dir "$lab_id")

    if [[ -z "$lab_dir" ]]; then
        echo -e "${RED}Error: Lab ${lab_id} not found.${NC}"
        echo "Run 'weaklink path' to see available labs."
        exit 1
    fi

    if [[ ! -f "${lab_dir}/verify.sh" ]]; then
        echo -e "${YELLOW}No verification script for lab ${lab_id}.${NC}"
        exit 1
    fi

    local pod
    pod=$(get_workstation_pod)
    if [[ -z "$pod" ]]; then
        echo -e "${RED}Error: Workstation pod not found.${NC}"
        exit 1
    fi

    echo -e "  ${CYAN}Verifying lab ${lab_id}...${NC}"
    echo ""

    # Copy verify script to the workstation pod and run it
    kubectl cp "${lab_dir}/verify.sh" "${NAMESPACE}/${pod}:/tmp/verify-${lab_id}.sh" 2>/dev/null
    if kubectl exec -n "$NAMESPACE" "$pod" -- bash "/tmp/verify-${lab_id}.sh"; then
        mark_completed "$lab_id"
        echo ""
        echo -e "  ${GREEN}${BOLD}Lab ${lab_id} completed!${NC}"
        echo ""

        # Suggest next lab
        local next_lab=""
        local found_current=false
        for dir in "$LABS_ROOT"/tier-*/*/; do
            [[ -f "${dir}/lab.yml" ]] || continue
            local lid
            lid=$(read_lab_yml "$dir" "id")
            if $found_current; then
                next_lab="$lid"
                break
            fi
            if [[ "$lid" == "$lab_id" ]]; then
                found_current=true
            fi
        done

        if [[ -n "$next_lab" ]]; then
            echo -e "  Next lab: ${BOLD}weaklink info ${next_lab}${NC}"
        fi
    else
        echo ""
        echo -e "  ${RED}Not quite -- check the output above and try again.${NC}"
        echo -e "  ${DIM}Run 'weaklink hint ${lab_id}' if you're stuck.${NC}"
    fi
}

cmd_hint() {
    local lab_id="$1"
    local lab_dir
    lab_dir=$(find_lab_dir "$lab_id")

    if [[ -z "$lab_dir" ]]; then
        echo -e "${RED}Error: Lab ${lab_id} not found.${NC}"
        exit 1
    fi

    local hint_num
    hint_num=$(get_hint_count "$lab_id")
    hint_num=$((hint_num + 1))

    local hint_file="${lab_dir}/hints/hint-${hint_num}.md"
    if [[ ! -f "$hint_file" ]]; then
        echo -e "${YELLOW}No more hints available for lab ${lab_id}.${NC}"
        echo -e "${DIM}Check the solution/ directory if you're completely stuck.${NC}"
        return
    fi

    increment_hint "$lab_id"

    local total_hints
    total_hints=$(find "${lab_dir}/hints" -name "hint-*.md" 2>/dev/null | wc -l | tr -d ' ')

    echo ""
    echo -e "  ${YELLOW}Hint ${hint_num}/${total_hints} for lab ${lab_id}${NC}"
    echo -e "  ────────────────────────────────"
    cat "$hint_file" | sed 's/^/  /'
    echo ""

    if [[ $hint_num -lt $total_hints ]]; then
        echo -e "  ${DIM}Run 'weaklink hint ${lab_id}' again for the next hint.${NC}"
    else
        echo -e "  ${DIM}That was the last hint. Check solution/ if still stuck.${NC}"
    fi
}

cmd_info() {
    local lab_id="$1"
    local lab_dir
    lab_dir=$(find_lab_dir "$lab_id")

    if [[ -z "$lab_dir" ]]; then
        echo -e "${RED}Error: Lab ${lab_id} not found.${NC}"
        exit 1
    fi

    echo ""
    echo -e "  ${BOLD}$(read_lab_yml "$lab_dir" "title")${NC}"
    echo -e "  ──────────────────────────────────────"
    echo -e "  ${DIM}ID:${NC}            $(read_lab_yml "$lab_dir" "id")"
    echo -e "  ${DIM}Tier:${NC}          $(read_lab_yml "$lab_dir" "tier")"
    echo -e "  ${DIM}Difficulty:${NC}    $(read_lab_yml "$lab_dir" "difficulty")"
    echo -e "  ${DIM}Time:${NC}          $(read_lab_yml "$lab_dir" "estimated_time")"
    echo -e "  ${DIM}Prerequisites:${NC} $(read_lab_yml "$lab_dir" "prerequisites")"
    echo -e "  ${DIM}Tags:${NC}          $(read_lab_yml "$lab_dir" "tags")"
    echo ""

    local phase_understand phase_break phase_defend
    phase_understand=$(read_lab_yml "$lab_dir" "phase_understand")
    phase_break=$(read_lab_yml "$lab_dir" "phase_break")
    phase_defend=$(read_lab_yml "$lab_dir" "phase_defend")

    echo -e "  ${BOLD}Phases:${NC}"
    [[ -n "$phase_understand" ]] && echo -e "    ${BLUE}1. UNDERSTAND${NC}  ${phase_understand}"
    [[ -n "$phase_break" ]]      && echo -e "    ${YELLOW}2. BREAK${NC}       ${phase_break}"
    [[ -n "$phase_defend" ]]     && echo -e "    ${GREEN}3. DEFEND${NC}      ${phase_defend}"
    echo ""
}

cmd_status() {
    check_cluster

    echo ""
    echo -e "  ${BOLD}WeakLink Labs -- Pod Status${NC}"
    echo -e "  ══════════════════════════════"
    echo ""

    kubectl get pods -n "$NAMESPACE" -o wide 2>/dev/null | sed 's/^/  /'
    echo ""

    # Check for setup job
    local job_status
    job_status=$(kubectl get job lab-setup -n "$NAMESPACE" -o jsonpath='{.status.conditions[0].type}' 2>/dev/null || echo "Unknown")
    echo -e "  ${DIM}Setup job: ${job_status}${NC}"

    # Show completed labs count
    local completed
    completed=$(find "$PROGRESS_DIR" -name "*.completed" 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  ${DIM}Labs completed: ${completed}${NC}"
    echo ""
}

cmd_logs() {
    check_cluster

    echo -e "  ${BOLD}Lab Setup Logs${NC}"
    echo -e "  ──────────────"
    echo ""

    kubectl logs -n "$NAMESPACE" job/lab-setup 2>/dev/null \
        || echo -e "  ${YELLOW}No logs found. The setup job may not have started yet.${NC}"
}

cmd_reset() {
    local lab_id="$1"
    local lab_dir
    lab_dir=$(find_lab_dir "$lab_id")

    if [[ -z "$lab_dir" ]]; then
        echo -e "${RED}Error: Lab ${lab_id} not found.${NC}"
        exit 1
    fi

    echo -e "  Resetting progress for lab ${lab_id}..."
    rm -f "${PROGRESS_DIR}/${lab_id}.completed" "${PROGRESS_DIR}/${lab_id}.hints"
    echo -e "  ${GREEN}Done.${NC} Progress reset for ${lab_id}."
}

cmd_assess() {
    echo ""
    echo -e "  ${BOLD}WEAKLINK LABS -- Placement Test${NC}"
    echo -e "  ═══════════════════════════════"
    echo ""
    echo -e "  ${DIM}10 questions on Git, package managers, and containers.${NC}"
    echo -e "  ${DIM}Score 8/10 or higher to skip Tier 0.${NC}"
    echo ""

    local score=0
    local total=${#ASSESS_QUESTIONS[@]}
    local wrong_topics=()
    local q_num=0

    for entry in "${ASSESS_QUESTIONS[@]}"; do
        q_num=$((q_num + 1))

        IFS='|' read -r question opt_a opt_b opt_c opt_d correct topic <<< "$entry"

        echo -e "  ${BOLD}${q_num}/${total}. ${question}${NC}"
        echo -e "    a) ${opt_a}"
        echo -e "    b) ${opt_b}"
        echo -e "    c) ${opt_c}"
        echo -e "    d) ${opt_d}"
        echo ""

        local answer=""
        while true; do
            read -p "  Your answer (a/b/c/d): " answer
            answer=$(echo "$answer" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
            if [[ "$answer" =~ ^[abcd]$ ]]; then
                break
            fi
            echo -e "  ${YELLOW}Please enter a, b, c, or d.${NC}"
        done

        if [[ "$answer" == "$correct" ]]; then
            echo -e "  ${GREEN}Correct.${NC}"
            score=$((score + 1))
        else
            echo -e "  ${RED}Incorrect.${NC} The answer is ${BOLD}${correct})${NC}."
            # Track unique wrong topics
            local already_tracked=false
            for t in "${wrong_topics[@]+"${wrong_topics[@]}"}"; do
                if [[ "$t" == "$topic" ]]; then
                    already_tracked=true
                    break
                fi
            done
            if ! $already_tracked; then
                wrong_topics+=("$topic")
            fi
        fi
        echo ""
    done

    echo -e "  ──────────────────────────────────────"
    echo -e "  ${BOLD}Score: ${score}/${total}${NC}"
    echo ""

    if [[ $score -ge 8 ]]; then
        # Mark Tier 0 labs as completed
        mark_completed "0.1"
        mark_completed "0.2"
        mark_completed "0.3"

        echo -e "  ${GREEN}${BOLD}Tier 0 skipped -- you're ready for Tier 1!${NC}"
        echo ""
        echo -e "  ${DIM}Labs 0.1, 0.2, and 0.3 marked as completed.${NC}"
        echo -e "  ${DIM}Run 'weaklink path' to see your updated roadmap.${NC}"
    else
        echo -e "  ${YELLOW}We recommend completing Tier 0 labs.${NC}"
        if [[ ${#wrong_topics[@]} -gt 0 ]]; then
            local areas
            areas=$(printf ", %s" "${wrong_topics[@]}")
            areas="${areas:2}"  # strip leading ", "
            echo -e "  ${DIM}Areas to review: ${areas}${NC}"
        fi
        echo ""
        echo -e "  ${DIM}Run 'weaklink path' to get started with Tier 0.${NC}"
    fi
    echo ""
}

#----------------------------------------------------------------------
# Collect all labs into parallel arrays (used by report commands)
#----------------------------------------------------------------------

collect_labs() {
    LAB_IDS=()
    LAB_TITLES=()
    LAB_TIERS=()
    LAB_TIER_NAMES=()
    LAB_TIMES=()

    for tier_dir in "$LABS_ROOT"/tier-*/; do
        [[ -d "$tier_dir" ]] || continue
        local tier_num
        tier_num=$(basename "$tier_dir" | grep -o 'tier-[0-9]*' | grep -o '[0-9]*')
        local tier_name
        tier_name=$(basename "$tier_dir" | sed 's/tier-[0-9]*-//' | tr '-' ' ' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')

        for lab_dir in "$tier_dir"/*/; do
            [[ -d "$lab_dir" ]] || continue
            [[ -f "${lab_dir}/lab.yml" ]] || continue

            LAB_IDS+=("$(read_lab_yml "$lab_dir" "id")")
            LAB_TITLES+=("$(read_lab_yml "$lab_dir" "title")")
            LAB_TIERS+=("$tier_num")
            LAB_TIER_NAMES+=("$tier_name")
            LAB_TIMES+=("$(read_lab_yml "$lab_dir" "estimated_time")")
        done
    done
}

# Parse estimated_time string (e.g. "25m", "1h30m") into minutes
parse_minutes() {
    local time_str="$1"
    local minutes=0
    if [[ "$time_str" =~ ([0-9]+)h ]]; then
        minutes=$(( ${BASH_REMATCH[1]} * 60 ))
    fi
    if [[ "$time_str" =~ ([0-9]+)m ]]; then
        minutes=$(( minutes + ${BASH_REMATCH[1]} ))
    fi
    echo "$minutes"
}

#----------------------------------------------------------------------
# Report commands
#----------------------------------------------------------------------

cmd_report_pretty() {
    collect_labs

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local total=${#LAB_IDS[@]}
    local completed=0
    local total_minutes=0
    local current_tier=""

    echo ""
    echo -e "${BOLD}WeakLink Labs -- Completion Report${NC}"
    echo -e "${DIM}Generated: ${now}${NC}"
    echo ""

    for i in "${!LAB_IDS[@]}"; do
        local lab_id="${LAB_IDS[$i]}"
        local title="${LAB_TITLES[$i]}"
        local tier="${LAB_TIERS[$i]}"
        local tier_name="${LAB_TIER_NAMES[$i]}"

        # Print tier header when tier changes
        if [[ "$tier" != "$current_tier" ]]; then
            [[ -n "$current_tier" ]] && echo ""
            echo -e "${BOLD}Tier ${tier}: ${tier_name}${NC}"
            current_tier="$tier"
        fi

        local status_icon status_text timestamp_text=""
        if is_completed "$lab_id"; then
            completed=$((completed + 1))
            local ts
            ts=$(cat "${PROGRESS_DIR}/${lab_id}.completed")
            status_icon="${GREEN}done${NC}"
            status_text="Completed"
            timestamp_text="  ${DIM}${ts}${NC}"
            total_minutes=$(( total_minutes + $(parse_minutes "${LAB_TIMES[$i]}") ))
        else
            status_icon="${DIM}    ${NC}"
            status_text="Not started"
        fi

        printf "  %-4s %-40s [%b]  %s%b\n" "$lab_id" "$title" "$status_icon" "$status_text" "$timestamp_text"
    done

    echo ""
    local pct=0
    [[ $total -gt 0 ]] && pct=$(( completed * 100 / total ))
    echo -e "${BOLD}Progress:${NC} ${completed}/${total} labs completed (${pct}%)"
    if [[ $total_minutes -gt 0 ]]; then
        echo -e "${BOLD}Total time:${NC} ~${total_minutes} minutes (estimated from completed labs)"
    fi
    echo ""
}

cmd_report_json() {
    collect_labs

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local user
    user="$(whoami)@$(hostname -s)"
    local total=${#LAB_IDS[@]}
    local completed=0

    echo "{"
    echo "  \"generated\": \"${now}\","
    echo "  \"user\": \"${user}\","
    echo "  \"labs\": {"

    for i in "${!LAB_IDS[@]}"; do
        local lab_id="${LAB_IDS[$i]}"
        local title="${LAB_TITLES[$i]}"
        local comma=","
        [[ $i -eq $((total - 1)) ]] && comma=""

        if is_completed "$lab_id"; then
            completed=$((completed + 1))
            local ts
            ts=$(cat "${PROGRESS_DIR}/${lab_id}.completed")
            echo "    \"${lab_id}\": {\"title\": \"${title}\", \"status\": \"completed\", \"completed_at\": \"${ts}\"}${comma}"
        else
            echo "    \"${lab_id}\": {\"title\": \"${title}\", \"status\": \"not_started\", \"completed_at\": null}${comma}"
        fi
    done

    local pct=0
    [[ $total -gt 0 ]] && pct=$(( completed * 100 / total ))

    echo "  },"
    echo "  \"summary\": {"
    echo "    \"total\": ${total},"
    echo "    \"completed\": ${completed},"
    echo "    \"percentage\": ${pct}"
    echo "  }"
    echo "}"
}

cmd_report_csv() {
    collect_labs

    echo "lab_id,title,status,completed_at"

    for i in "${!LAB_IDS[@]}"; do
        local lab_id="${LAB_IDS[$i]}"
        local title="${LAB_TITLES[$i]}"

        if is_completed "$lab_id"; then
            local ts
            ts=$(cat "${PROGRESS_DIR}/${lab_id}.completed")
            echo "${lab_id},\"${title}\",completed,${ts}"
        else
            echo "${lab_id},\"${title}\",not_started,"
        fi
    done
}

cmd_report_team() {
    local dir_path=""
    local args=("$@")

    # Parse --dir flag
    for i in "${!args[@]}"; do
        if [[ "${args[$i]}" == "--dir" ]] && [[ -n "${args[$((i+1))]:-}" ]]; then
            dir_path="${args[$((i+1))]}"
        fi
    done

    local json_files=()

    if [[ -n "$dir_path" ]]; then
        # Read JSON files from directory
        if [[ ! -d "$dir_path" ]]; then
            echo -e "${RED}Error: Directory '${dir_path}' not found.${NC}" >&2
            exit 1
        fi
        while IFS= read -r f; do
            json_files+=("$f")
        done < <(find "$dir_path" -maxdepth 1 -name "*.json" -type f 2>/dev/null | sort)

        if [[ ${#json_files[@]} -eq 0 ]]; then
            echo -e "${RED}Error: No .json files found in '${dir_path}'.${NC}" >&2
            exit 1
        fi
    elif [[ ! -t 0 ]]; then
        # Read from stdin -- split concatenated JSON objects into temp files
        local tmpdir
        tmpdir=$(mktemp -d)
        trap "rm -rf '$tmpdir'" EXIT

        local file_idx=0
        local brace_depth=0
        local current_file=""

        while IFS= read -r line; do
            local open close
            open=$(echo "$line" | tr -cd '{' | wc -c | tr -d ' ')
            close=$(echo "$line" | tr -cd '}' | wc -c | tr -d ' ')

            if [[ $brace_depth -eq 0 && $open -gt 0 ]]; then
                current_file="${tmpdir}/report_${file_idx}.json"
                file_idx=$((file_idx + 1))
            fi

            if [[ -n "$current_file" ]]; then
                echo "$line" >> "$current_file"
            fi

            brace_depth=$(( brace_depth + open - close ))

            if [[ $brace_depth -eq 0 && -n "$current_file" ]]; then
                json_files+=("$current_file")
                current_file=""
            fi
        done

        if [[ ${#json_files[@]} -eq 0 ]]; then
            echo -e "${RED}Error: No valid JSON reports found on stdin.${NC}" >&2
            exit 1
        fi
    else
        echo -e "${RED}Error: --team requires piped input or --dir <path>.${NC}" >&2
        echo "" >&2
        echo "Usage:" >&2
        echo "  cat report1.json report2.json | weaklink report --team" >&2
        echo "  weaklink report --team --dir ./reports/" >&2
        exit 1
    fi

    # Aggregate reports
    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    echo ""
    echo -e "${BOLD}WeakLink Labs -- Team Completion Report${NC}"
    echo -e "${DIM}Generated: ${now}${NC}"
    echo -e "${DIM}Analysts:  ${#json_files[@]}${NC}"
    echo ""

    # Header
    printf "  ${BOLD}%-30s  %10s  %10s${NC}\n" "Analyst" "Completed" "Progress"
    echo "  ──────────────────────────────────────────────────────"

    local team_total=0
    local team_completed=0

    for jf in "${json_files[@]}"; do
        local user total comp pct
        user=$(grep '"user"' "$jf" | head -1 | sed 's/.*: *"//' | sed 's/".*//')
        total=$(grep '"total"' "$jf" | head -1 | sed 's/.*: *//' | sed 's/[^0-9].*//')
        # Match "completed": <number> in summary, not "status": "completed" lines
        comp=$(grep '"completed":' "$jf" | grep '[0-9]' | head -1 | sed 's/.*: *//' | sed 's/[^0-9].*//')
        pct=$(grep '"percentage"' "$jf" | head -1 | sed 's/.*: *//' | sed 's/[^0-9].*//')

        [[ -z "$total" ]] && total=0
        [[ -z "$comp" ]] && comp=0
        [[ -z "$pct" ]] && pct=0

        team_total=$((team_total + total))
        team_completed=$((team_completed + comp))

        # Color based on progress
        local color="$RED"
        [[ $pct -ge 33 ]] && color="$YELLOW"
        [[ $pct -ge 66 ]] && color="$GREEN"

        # Build a mini progress bar (20 chars wide)
        local bar_filled=$(( pct * 20 / 100 ))
        local bar_empty=$(( 20 - bar_filled ))
        local bar=""
        local b
        for ((b=0; b<bar_filled; b++)); do bar+="█"; done
        for ((b=0; b<bar_empty; b++)); do bar+="░"; done

        printf "  %-30s  %5s/%-4s  %b%s%b %3s%%\n" "$user" "$comp" "$total" "$color" "$bar" "$NC" "$pct"
    done

    echo "  ──────────────────────────────────────────────────────"

    local team_pct=0
    [[ $team_total -gt 0 ]] && team_pct=$(( team_completed * 100 / team_total ))

    printf "  ${BOLD}%-30s  %5s/%-4s  %3s%%${NC}\n" "TOTAL" "$team_completed" "$team_total" "$team_pct"
    echo ""

    # Per-lab breakdown across analysts
    echo -e "${BOLD}Per-Lab Completion:${NC}"
    echo ""

    # Collect all unique lab IDs from the first report
    local lab_ids=()
    local lab_titles=()
    local first_file="${json_files[0]}"

    while IFS= read -r line; do
        if [[ "$line" =~ \"([0-9]+\.[0-9]+)\":[[:space:]]*\{.*\"title\":[[:space:]]*\"([^\"]+)\" ]]; then
            lab_ids+=("${BASH_REMATCH[1]}")
            lab_titles+=("${BASH_REMATCH[2]}")
        fi
    done < "$first_file"

    for li in "${!lab_ids[@]}"; do
        local lid="${lab_ids[$li]}"
        local ltitle="${lab_titles[$li]}"
        local lab_comp=0

        for jf in "${json_files[@]}"; do
            if grep -q "\"${lid}\".*\"completed\"" "$jf" 2>/dev/null; then
                lab_comp=$((lab_comp + 1))
            fi
        done

        local ratio="${lab_comp}/${#json_files[@]}"
        local lab_color="$RED"
        [[ $lab_comp -eq ${#json_files[@]} ]] && lab_color="$GREEN"
        [[ $lab_comp -gt 0 && $lab_comp -lt ${#json_files[@]} ]] && lab_color="$YELLOW"

        printf "  %-4s %-40s %b%s%b\n" "$lid" "$ltitle" "$lab_color" "$ratio" "$NC"
    done
    echo ""
}

