{
  "name": "WeakLink Labs",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workstation",
  "workspaceFolder": "/home/labs",
  "forwardPorts": [8000, 7681, 7682],
  "portsAttributes": {
    "8000": {"label": "Guide", "onAutoForward": "openBrowser"},
    "7681": {"label": "Terminal", "onAutoForward": "silent"},
    "7682": {"label": "Verify API", "onAutoForward": "silent"}
  },
  "waitFor": "onCreateCommand",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "echo 'WeakLink Labs ready. Open the Guide tab or visit port 8000.'"
}
