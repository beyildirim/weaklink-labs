{
  "_account": "444444444444 (Production Account)",
  "_role": "prod-deploy",
  "_description": "Role for production deployments -- has access to customer data and secrets",

  "AssumeRolePolicyDocument": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {
          "AWS": "arn:aws:iam::333333333333:root"
        },
        "Action": "sts:AssumeRole",
        "_vulnerability": "Trusts the entire Staging Account. Once staging-deploy is compromised, production is compromised."
      }
    ]
  },

  "PermissionPolicy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "ProductionDeploy",
        "Effect": "Allow",
        "Action": [
          "ecs:UpdateService",
          "ecs:DescribeServices",
          "ecs:RegisterTaskDefinition"
        ],
        "Resource": "*"
      },
      {
        "Sid": "ProductionImages",
        "Effect": "Allow",
        "Action": [
          "ecr:GetAuthorizationToken",
          "ecr:BatchGetImage",
          "ecr:GetDownloadUrlForLayer",
          "ecr:PutImage"
        ],
        "Resource": "arn:aws:ecr:us-east-1:444444444444:repository/prod-images"
      },
      {
        "Sid": "CustomerData",
        "Effect": "Allow",
        "Action": "s3:*",
        "Resource": [
          "arn:aws:s3:::customer-data-444444444444",
          "arn:aws:s3:::customer-data-444444444444/*"
        ]
      },
      {
        "Sid": "ProductionDatabase",
        "Effect": "Allow",
        "Action": "dynamodb:*",
        "Resource": "arn:aws:dynamodb:us-east-1:444444444444:table/orders-*"
      },
      {
        "Sid": "ProductionSecrets",
        "Effect": "Allow",
        "Action": "secretsmanager:GetSecretValue",
        "Resource": "arn:aws:secretsmanager:us-east-1:444444444444:secret:prod/*"
      }
    ]
  }
}
