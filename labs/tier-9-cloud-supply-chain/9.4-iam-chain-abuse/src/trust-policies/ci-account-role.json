{
  "_account": "222222222222 (CI Account)",
  "_role": "ci-runner",
  "_description": "Role assumed by CI pipelines to build and deploy to staging",

  "AssumeRolePolicyDocument": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {
          "AWS": "arn:aws:iam::111111111111:root"
        },
        "Action": "sts:AssumeRole",
        "_vulnerability": "Trusts the entire Dev Account -- any role/user in 111111111111 can assume this"
      }
    ]
  },

  "PermissionPolicy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "BuildAccess",
        "Effect": "Allow",
        "Action": [
          "codebuild:StartBuild",
          "codebuild:BatchGetBuilds"
        ],
        "Resource": "arn:aws:codebuild:us-east-1:222222222222:project/*"
      },
      {
        "Sid": "BuildArtifacts",
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:PutObject"
        ],
        "Resource": "arn:aws:s3:::build-artifacts-222222222222/*"
      },
      {
        "Sid": "PushStagingImages",
        "Effect": "Allow",
        "Action": [
          "ecr:GetAuthorizationToken",
          "ecr:PutImage",
          "ecr:BatchCheckLayerAvailability",
          "ecr:InitiateLayerUpload",
          "ecr:UploadLayerPart",
          "ecr:CompleteLayerUpload"
        ],
        "Resource": "arn:aws:ecr:us-east-1:222222222222:repository/staging-images"
      },
      {
        "Sid": "DeployToStaging",
        "Effect": "Allow",
        "Action": "sts:AssumeRole",
        "Resource": "arn:aws:iam::333333333333:role/staging-deploy",
        "_vulnerability": "No ExternalId, no source IP condition, no MFA"
      }
    ]
  }
}
