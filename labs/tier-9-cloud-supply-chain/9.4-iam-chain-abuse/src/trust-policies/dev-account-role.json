{
  "_account": "111111111111 (Dev Account)",
  "_role": "dev-deploy",
  "_description": "Role used by developers to push code and trigger CI builds",

  "AssumeRolePolicyDocument": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": {
          "AWS": "arn:aws:iam::111111111111:root"
        },
        "Action": "sts:AssumeRole"
      }
    ]
  },

  "PermissionPolicy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "CodeCommitAccess",
        "Effect": "Allow",
        "Action": [
          "codecommit:GitPush",
          "codecommit:GitPull",
          "codecommit:CreatePullRequest"
        ],
        "Resource": "arn:aws:codecommit:us-east-1:111111111111:*"
      },
      {
        "Sid": "DevArtifacts",
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:PutObject"
        ],
        "Resource": "arn:aws:s3:::dev-artifacts-111111111111/*"
      },
      {
        "Sid": "TriggerCI",
        "Effect": "Allow",
        "Action": "sts:AssumeRole",
        "Resource": "arn:aws:iam::222222222222:role/ci-runner",
        "_vulnerability": "No conditions -- any entity with dev-deploy creds can assume ci-runner"
      }
    ]
  }
}
